<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->

    <bean id="courseBean"
          class="com.harsh.DependencyDemoSetter.Course">

        <property name="courseName" value="Spring Framework"/>
    </bean>
    <bean id="studentBean"
          class="com.harsh.DependencyDemoSetter.Student">

        <property name="studentName" value="Harsh"/>

        <!-- Inject another bean -->
        <property name="course" ref="courseBean"/>
    </bean>

</beans>